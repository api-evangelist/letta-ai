{
  "info": {
    "name": "Letta API",
    "description": "Programmatic creation, configuration, and messaging of stateful Letta agents - persistent memory blocks and archives, tools and MCP servers, data sources, identities, multi-agent groups, models/providers, and run/job/step observability. Base URL: https://api.letta.com/v1 (Cloud) or http://localhost:8283/v1 (self-hosted). All requests require a Bearer API key.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearerToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://api.letta.com/v1",
      "type": "string"
    },
    {
      "key": "bearerToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Agents",
      "item": [
        {
          "name": "Get a list of all agents",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/agents",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "agents"
              ]
            },
            "description": "Get a list of all agents."
          }
        },
        {
          "name": "Create an agent",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
