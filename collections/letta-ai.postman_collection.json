              "mode": "raw",
              "raw": "{\n  \"name\": \"customer-support-agent\",\n  \"model\": \"openai/gpt-4o\",\n  \"embedding\": \"openai/text-embedding-3-small\",\n  \"memory_blocks\": [\n    {\n      \"label\": \"persona\",\n      \"value\": \"I am a helpful customer support agent.\"\n    }\n  ]\n}"
            }
          }
        },
